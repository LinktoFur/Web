---
const BASE_URL = 'https://api.furry.luxe/moke/';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moke</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css@5.5.0/github-markdown.min.css">
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    
    :root {
      --c-bg: #0a0a0b;
      --c-bg-soft: #141416;
      --c-bg-mute: #1e1e21;
      --c-border: #2e2e32;
      --c-text: #ffffffde;
      --c-text-2: #ffffffaa;
      --c-text-3: #ffffff66;
      --c-brand: #646cff;
      --c-brand-light: #747bff;
      --c-highlight-bg: rgba(100, 108, 255, 0.14);
      --c-highlight-text: #a8b1ff;
      --sidebar-width: 260px;
      --header-height: 56px;
      --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    [data-theme="light"] {
      --c-bg: #ffffff;
      --c-bg-soft: #f9f9f9;
      --c-bg-mute: #f1f1f1;
      --c-border: #e2e2e3;
      --c-text: #213547;
      --c-text-2: #476582;
      --c-text-3: #8e8e93;
      --c-highlight-bg: rgba(100, 108, 255, 0.08);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    html, body { 
      height: 100%;
      font-family: var(--font);
      background: var(--c-bg);
      color: var(--c-text);
      -webkit-font-smoothing: antialiased;
    }

    /* Header */
    .header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--header-height);
      background: var(--c-bg);
      border-bottom: 1px solid var(--c-border);
      z-index: 200;
      display: flex;
      align-items: center;
      padding: 0 20px;
    }

    .header-left {
      width: var(--sidebar-width);
      flex-shrink: 0;
      padding-right: 20px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 17px;
      font-weight: 600;
      color: var(--c-text);
      text-decoration: none;
    }

    .logo-icon {
      width: 26px;
      height: 26px;
      background: var(--c-brand);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 13px;
    }

    .header-center {
      flex: 1;
      display: flex;
      justify-content: center;
      padding: 0 20px;
    }

    .header-right {
      flex-shrink: 0;
    }

    /* Search */
    .search-wrap {
      width: 100%;
      max-width: 480px;
      position: relative;
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 14px;
      height: 40px;
      background: var(--c-bg-soft);
      border: 1px solid var(--c-border);
      border-radius: 8px;
      transition: all 0.2s;
    }

    .search-box:focus-within {
      border-color: var(--c-brand);
      box-shadow: 0 0 0 3px var(--c-highlight-bg);
    }

    .search-box svg {
      width: 16px;
      height: 16px;
      color: var(--c-text-3);
      flex-shrink: 0;
    }

    .search-box input {
      flex: 1;
      height: 100%;
      border: none;
      background: transparent;
      font-size: 14px;
      color: var(--c-text);
      outline: none;
    }

    .search-box input::placeholder { color: var(--c-text-3); }

    .search-box kbd {
      padding: 3px 7px;
      font-size: 11px;
      color: var(--c-text-3);
      background: var(--c-bg-mute);
      border: 1px solid var(--c-border);
      border-radius: 4px;
    }

    .search-results {
      display: none;
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: var(--c-bg-soft);
      border: 1px solid var(--c-border);
      border-radius: 10px;
      max-height: 400px;
      overflow-y: auto;
      box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    }

    .search-results.show { display: block; }

    .result-item {
      padding: 12px 16px;
      cursor: pointer;
      border-bottom: 1px solid var(--c-border);
    }

    .result-item:last-child { border-bottom: none; }
    .result-item:hover { background: var(--c-bg-mute); }

    .result-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--c-text);
      margin-bottom: 4px;
    }

    .result-path {
      font-size: 12px;
      color: var(--c-brand-light);
    }

    .result-preview {
      font-size: 13px;
      color: var(--c-text-2);
      margin-top: 6px;
      line-height: 1.5;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .result-preview mark {
      background: rgba(100, 108, 255, 0.3);
      color: var(--c-brand-light);
      padding: 1px 3px;
      border-radius: 3px;
    }

    .no-result {
      padding: 24px;
      text-align: center;
      font-size: 14px;
      color: var(--c-text-3);
    }

    .theme-toggle, .menu-toggle {
      width: 36px;
      height: 36px;
      border: none;
      background: transparent;
      color: var(--c-text-2);
      cursor: pointer;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .theme-toggle:hover, .menu-toggle:hover {
      color: var(--c-text);
      background: var(--c-bg-mute);
    }

    .theme-toggle svg, .menu-toggle svg { width: 18px; height: 18px; }

    .menu-toggle { display: none; }

    .header-right { display: flex; align-items: center; gap: 4px; }

    /* Mobile overlay */
    .overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 150;
    }
    .overlay.show { display: block; }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-left">
      <a href="/" class="logo" id="logoBtn">
        <span class="logo-icon">M</span>
        <span>Moke</span>
      </a>
    </div>
    <div class="header-center">
      <div class="search-wrap">
        <div class="search-box">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input type="text" id="searchInput" placeholder="搜索文档..." autocomplete="off">
          <kbd>⌘K</kbd>
        </div>
        <div class="search-results" id="searchResults"></div>
      </div>
    </div>
    <div class="header-right">
      <button class="theme-toggle" id="themeToggle" title="切换主题">
        <svg id="moonIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="sunIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>
      <button class="menu-toggle" id="menuToggle" title="菜单">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </header>
  <div class="overlay" id="overlay"></div>


  <style is:global>
    /* Layout */
    .layout {
      display: flex;
      padding-top: var(--header-height);
    }

    /* Sidebar */
    .sidebar {
      width: var(--sidebar-width);
      height: calc(100vh - var(--header-height));
      position: fixed;
      left: 0;
      top: var(--header-height);
      background: var(--c-bg-soft);
      border-right: 1px solid var(--c-border);
      overflow-y: auto;
      padding: 12px 8px;
    }

    .nav-group { margin-bottom: 8px; }

    .nav-group-title {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 600;
      color: var(--c-text-2);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      border-radius: 6px;
      user-select: none;
    }

    .nav-group-title:hover { background: var(--c-bg-mute); }

    .nav-group-title .folder-icon {
      width: 14px;
      height: 14px;
      color: var(--c-brand);
    }

    .nav-group-title .chevron {
      width: 14px;
      height: 14px;
      color: var(--c-text-3);
      margin-left: auto;
      transition: transform 0.2s;
    }

    .nav-group.collapsed .nav-group-title .chevron {
      transform: rotate(-90deg);
    }

    .nav-group-items {
      padding-left: 8px;
      overflow: hidden;
      max-height: 1000px;
      transition: max-height 0.3s ease, opacity 0.2s ease, padding 0.2s ease;
      opacity: 1;
    }

    .nav-group.collapsed .nav-group-items {
      max-height: 0;
      opacity: 0;
      padding-top: 0;
      padding-bottom: 0;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      font-size: 14px;
      color: var(--c-text-2);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .nav-item:hover {
      background: var(--c-bg-mute);
      color: var(--c-text);
    }

    .nav-item.active {
      background: var(--c-highlight-bg);
      color: var(--c-brand);
    }

    .nav-item svg {
      width: 14px;
      height: 14px;
      color: var(--c-text-3);
      flex-shrink: 0;
    }

    .nav-item.active svg { color: var(--c-brand); }

    .nav-item-text {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Main */
    .main {
      flex: 1;
      margin-left: var(--sidebar-width);
      min-height: calc(100vh - var(--header-height));
    }

    .welcome {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: calc(100vh - var(--header-height));
    }

    .welcome-inner { text-align: center; }

    .welcome h1 {
      font-size: 48px;
      font-weight: 700;
      background: linear-gradient(120deg, var(--c-brand) 30%, #42d392);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 12px;
    }

    .welcome p {
      font-size: 16px;
      color: var(--c-text-3);
    }

    .article-view {
      display: none;
      padding: 40px 32px;
    }

    .article-view.show { display: block; }

    .article-inner {
      max-width: 760px;
      margin: 0 auto;
    }

    .article-meta {
      font-size: 13px;
      color: var(--c-brand-light);
      margin-bottom: 12px;
    }

    .article-title {
      font-size: 36px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 32px;
    }

    .markdown-body {
      background: transparent !important;
      color: var(--c-text) !important;
      font-size: 16px;
      line-height: 1.75;
    }

    [data-theme="dark"] .markdown-body { color-scheme: dark; }

    /* Table styles */
    .markdown-body table {
      border-collapse: collapse;
      width: 100%;
      margin: 16px 0;
      background: transparent !important;
    }

    .markdown-body thead {
      background: var(--c-bg-mute) !important;
    }

    .markdown-body tbody {
      background: transparent !important;
    }

    .markdown-body th,
    .markdown-body td {
      border: 1px solid var(--c-border) !important;
      padding: 10px 14px;
      text-align: left;
      background: transparent !important;
    }

    .markdown-body th {
      background: var(--c-bg-mute) !important;
      font-weight: 600;
    }

    .markdown-body tbody tr {
      background: transparent !important;
    }

    .markdown-body tbody tr:nth-child(even) {
      background: var(--c-bg-soft) !important;
    }

    .markdown-body tbody tr:hover {
      background: var(--c-bg-mute) !important;
    }

    /* Code block styles */
    .markdown-body pre {
      background: var(--c-bg-soft) !important;
      border: 1px solid var(--c-border);
      border-radius: 8px;
    }

    .markdown-body code {
      background: var(--c-bg-mute);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 0.9em;
    }

    .markdown-body pre code {
      background: transparent;
      padding: 0;
    }

    /* Blockquote */
    .markdown-body blockquote {
      border-left: 4px solid var(--c-brand);
      background: var(--c-bg-soft);
      padding: 12px 16px;
      margin: 16px 0;
      color: var(--c-text-2);
    }

    .search-highlight {
      background: rgba(100, 108, 255, 0.3);
      color: var(--c-brand-light);
      padding: 2px 4px;
      border-radius: 3px;
    }

    @media (max-width: 768px) {
      .header { padding: 0 12px; gap: 0; }
      .header-left { width: auto; padding: 0; flex-shrink: 0; }
      .header-center { flex: 1; padding: 0 12px; }
      .header-right { flex-shrink: 0; }
      .search-wrap { max-width: 100%; width: 100%; }
      .logo { cursor: pointer; }
      .logo span:last-child { display: none; }
      
      .sidebar {
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        z-index: 160;
        width: 280px;
      }
      .sidebar.open { transform: translateX(0); }
      
      .main { margin-left: 0; }
      .menu-toggle { display: flex; }
      .search-box kbd { display: none; }
      .search-box { height: 38px; padding: 0 12px; }
      .search-box input { font-size: 14px; min-width: 0; }
      
      .article-view { padding: 24px 16px; }
      .article-title { font-size: 24px; }
      .welcome h1 { font-size: 36px; }
      .welcome p { font-size: 14px; }
    }
  </style>

  <div class="layout">
    <aside class="sidebar" id="sidebar"></aside>
    <main class="main">
      <div class="welcome" id="welcomeView">
        <div class="welcome-inner">
          <h1>Moke</h1>
          <p>从左侧选择文档开始阅读</p>
        </div>
      </div>
      <article class="article-view" id="articleView">
        <div class="article-inner">
          <div class="article-meta" id="articleMeta"></div>
          <h1 class="article-title" id="articleTitle"></h1>
          <div class="markdown-body" id="articleBody"></div>
        </div>
      </article>
    </main>
  </div>


  <script is:inline define:vars={{ BASE_URL }}>
    const API = BASE_URL;
    let articles = [];
    const $ = id => document.getElementById(id);

    // Theme
    const theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.dataset.theme = theme;
    updateThemeIcon(theme);

    $('themeToggle').onclick = () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      updateThemeIcon(next);
    };

    function updateThemeIcon(t) {
      $('moonIcon').style.display = t === 'dark' ? 'block' : 'none';
      $('sunIcon').style.display = t === 'light' ? 'block' : 'none';
    }

    // Mobile menu
    const sidebar = $('sidebar');
    const overlay = $('overlay');
    
    function toggleMenu() {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('show');
    }
    
    $('menuToggle').onclick = toggleMenu;
    
    // Logo click - open menu on mobile
    $('logoBtn').onclick = e => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        toggleMenu();
      }
    };
    
    overlay.onclick = () => {
      sidebar.classList.remove('open');
      overlay.classList.remove('show');
    };

    // Load articles
    fetch(API + 'api.php').then(r => r.json()).then(data => {
      if (!data.folders) return;
      const loaded = {};
      let pending = data.folders.length;

      data.folders.forEach(folder => {
        fetch(API + 'api.php?category=' + encodeURIComponent(folder))
          .then(r => r.json())
          .then(d => {
            if (d.articles) {
              d.articles.forEach(a => {
                const key = a.path + '/' + a.name;
                if (!loaded[key]) {
                  loaded[key] = true;
                  articles.push({ path: a.path, name: a.name, content: a.content });
                }
              });
            }
            pending--;
            if (pending === 0) renderNav();
          });
      });
    });

    function renderNav() {
      const grouped = {};
      articles.forEach(a => {
        if (!grouped[a.path]) grouped[a.path] = [];
        grouped[a.path].push(a);
      });

      const sidebar = $('sidebar');
      sidebar.innerHTML = Object.keys(grouped).map(path => `
        <div class="nav-group collapsed">
          <div class="nav-group-title">
            <svg class="folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            </svg>
            <span>${path}</span>
            <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </div>
          <div class="nav-group-items">
            ${grouped[path].map((a, i) => `
              <div class="nav-item" data-path="${path}" data-idx="${i}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                <span class="nav-item-text">${a.name.replace('.md', '')}</span>
              </div>
            `).join('')}
          </div>
        </div>
      `).join('');

      // Toggle collapse
      sidebar.querySelectorAll('.nav-group-title').forEach(el => {
        el.onclick = () => {
          el.parentElement.classList.toggle('collapsed');
        };
      });

      sidebar.querySelectorAll('.nav-item').forEach(el => {
        el.onclick = e => {
          e.stopPropagation();
          const path = el.dataset.path;
          const idx = parseInt(el.dataset.idx);
          showArticle(grouped[path][idx], el, null);
        };
      });
    }

    function showArticle(a, navEl, keyword) {
      $('welcomeView').style.display = 'none';
      $('articleView').classList.add('show');
      $('articleMeta').textContent = a.path;
      $('articleTitle').textContent = a.name.replace('.md', '');
      
      // Remove search tag before display
      let content = a.content;
      if (content.trim().startsWith('#need114514')) {
        content = content.replace('#need114514', '').replace(/^\n+/, '');
      }
      let html = marked.parse(content);
      // Highlight and mark keyword for scrolling
      if (keyword) {
        const escKeyword = esc(keyword);
        html = html.replace(
          new RegExp('(' + escKeyword + ')', 'gi'),
          '<mark class="search-highlight" data-highlight="true">$1</mark>'
        );
      }
      $('articleBody').innerHTML = html;

      document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
      if (navEl) navEl.classList.add('active');

      $('searchResults').classList.remove('show');
      // Close mobile menu
      sidebar.classList.remove('open');
      overlay.classList.remove('show');
      
      // Scroll to first highlight
      if (keyword) {
        setTimeout(() => {
          const highlight = document.querySelector('.search-highlight[data-highlight="true"]');
          if (highlight) {
            highlight.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }, 100);
      } else {
        window.scrollTo(0, 0);
      }
    }

    // Search
    const searchInput = $('searchInput');
    const searchResults = $('searchResults');
    let timer;

    searchInput.oninput = e => {
      clearTimeout(timer);
      const q = e.target.value.trim();
      if (q.length < 2) { searchResults.classList.remove('show'); return; }
      timer = setTimeout(() => search(q), 150);
    };

    searchInput.onfocus = () => {
      if (searchInput.value.trim().length >= 2) searchResults.classList.add('show');
    };

    document.onclick = e => {
      if (!e.target.closest('.search-wrap')) searchResults.classList.remove('show');
    };

    document.onkeydown = e => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchInput.focus();
      }
      if (e.key === 'Escape') searchResults.classList.remove('show');
    };

    function esc(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

    function stripMarkdown(text) {
      return text
        .replace(/^#{1,6}\s+/gm, '')
        .replace(/\*\*([^*]+)\*\*/g, '$1')
        .replace(/\*([^*]+)\*/g, '$1')
        .replace(/`([^`]+)`/g, '$1')
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
        .replace(/!\[([^\]]*)\]\([^)]+\)/g, '')
        .replace(/^[-*+]\s+/gm, '')
        .replace(/^\d+\.\s+/gm, '')
        .replace(/^>\s+/gm, '')
        .replace(/\|/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function getAllMatches(content, query) {
      const clean = stripMarkdown(content);
      const lc = clean.toLowerCase();
      const lq = query.toLowerCase();
      const matches = [];
      let pos = 0;
      while (pos < lc.length) {
        const idx = lc.indexOf(lq, pos);
        if (idx === -1) break;
        const start = Math.max(0, idx - 30);
        const end = Math.min(clean.length, idx + query.length + 50);
        let text = clean.slice(start, end);
        if (start > 0) text = '...' + text;
        if (end < clean.length) text = text + '...';
        text = text.replace(new RegExp('(' + esc(query) + ')', 'gi'), '<mark>$1</mark>');
        matches.push({ idx, preview: text });
        pos = idx + query.length;
      }
      return matches;
    }

    const SEARCH_TAG = '#need114514';

    function isSearchable(content) {
      return content.trim().startsWith(SEARCH_TAG);
    }

    function getDisplayContent(content) {
      if (content.trim().startsWith(SEARCH_TAG)) {
        return content.replace(SEARCH_TAG, '').replace(/^\n+/, '');
      }
      return content;
    }

    function search(q) {
      const lq = q.toLowerCase();
      const results = [];
      
      articles.forEach(a => {
        if (!isSearchable(a.content)) return;
        
        const displayContent = getDisplayContent(a.content);
        const nameMatch = a.name.toLowerCase().includes(lq);
        const matches = getAllMatches(displayContent, q);
        
        if (matches.length > 0) {
          matches.forEach(m => {
            results.push({ article: a, preview: m.preview, matchIdx: m.idx });
          });
        } else if (nameMatch) {
          results.push({ article: a, preview: '', matchIdx: -1 });
        }
      });

      if (!results.length) {
        searchResults.innerHTML = '<div class="no-result">没有找到结果</div>';
      } else {
        searchResults.innerHTML = results.slice(0, 10).map((r, i) => {
          return '<div class="result-item" data-i="' + i + '">' +
            '<div class="result-title">' + r.article.name.replace('.md', '') + '</div>' +
            '<div class="result-path">' + r.article.path + '</div>' +
            (r.preview ? '<div class="result-preview">' + r.preview + '</div>' : '') +
          '</div>';
        }).join('');

        const resRef = results;
        searchResults.querySelectorAll('.result-item').forEach((el, i) => {
          el.onclick = () => resRef[i] && showArticle(resRef[i].article, null, q);
        });
      }
      searchResults.classList.add('show');
    }

    searchInput.focus();
  </script>
</body>
</html>
