---
import '../styles/global.css';

const BASE_URL = 'https://moke.furry.luxe/';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Primary Meta Tags -->
  <title>查找大学兽迷 - 高校兽迷同好汇 - LinktoFur兽迷互联</title>
  <meta name="title" content="查找大学兽迷 - 高校兽迷同好汇 - LinktoFur兽迷互联">
  <meta name="description" content="LinktoFur兽迷互联 - 连接全国高校兽迷同好，搜索你的院校或地区联合群，加入兽圈社区，结识志同道合的朋友。">
  <meta name="keywords" content="兽迷,furry,高校兽迷,大学兽迷,兽圈,兽迷社区,兽迷群,LinktoFur,院校兽迷,地区联合群">
  <meta name="author" content="LinktoFur">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://linktofur.net/">
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://linktofur.net/">
  <meta property="og:title" content="查找大学兽迷 - 高校兽迷同好汇 - LinktoFur兽迷互联">
  <meta property="og:description" content="LinktoFur兽迷互联 - 连接全国高校兽迷同好，搜索你的院校或地区联合群，加入兽圈社区，结识志同道合的朋友。">
  <meta property="og:locale" content="zh_CN">
  <meta property="og:site_name" content="LinktoFur兽迷互联">
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:url" content="https://linktofur.net/">
  <meta name="twitter:title" content="查找大学兽迷 - 高校兽迷同好汇 - LinktoFur兽迷互联">
  <meta name="twitter:description" content="LinktoFur兽迷互联 - 连接全国高校兽迷同好，搜索你的院校或地区联合群，加入兽圈社区，结识志同道合的朋友。">
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="https://moke.furry.luxe/favicon.ico">
  
  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://cdn.jsdmirror.com">
  <link rel="dns-prefetch" href="https://cdn.jsdmirror.com">
  
  <!-- Stylesheets -->
  <link rel="stylesheet" href="https://cdn.jsdmirror.com/npm/github-markdown-css@5.5.0/github-markdown.min.css">
  
  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "LinktoFur兽迷互联",
    "url": "https://linktofur.net/",
    "description": "连接全国高校兽迷同好，搜索你的院校或地区联合群",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://linktofur.net/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "LinktoFur",
    "url": "https://linktofur.net/",
    "logo": "https://linktofur.net/favicon.ico",
    "sameAs": []
  }
  </script>
</head>
<body>
  <noscript>
    <div style="padding:20px;text-align:center;background:#f44336;color:white;">
      本网站需要启用JavaScript才能正常运行。请在浏览器设置中启用JavaScript。
    </div>
  </noscript>
  
  <nav class="navbar" role="navigation" aria-label="主导航">
    <div class="nav-brand">LinktoFur</div>
    <div class="nav-links">
      <button class="nav-link active" data-page="home">首页</button>
      <button class="nav-link" data-page="docs">文档</button>
      <button class="nav-link" data-page="about">关于我们</button>
    </div>
    <div class="nav-right">
      <button class="theme-toggle" id="themeToggle" title="切换主题">
        <svg id="moonIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg id="sunIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      </button>
    </div>
  </nav>

  <main class="home-page active" id="homePage" role="main">
    <h1 class="logo">搜索院校或地区群</h1>
    <p class="subtitle">🐾🔍️</p>
    <div class="search-wrap">
      <div class="custom-select-wrapper">
        <div class="custom-select" id="customCategorySelect">
          <span id="categoryLabel">院校</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </div>
        <div class="custom-select-dropdown" id="categoryDropdown">
          <div class="custom-select-option selected" data-value="school">院校</div>
          <div class="custom-select-option" data-value="union">地区联合群</div>
        </div>
      </div>
      <div class="search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="searchInput" placeholder="输入学校名称..." autocomplete="off">
      </div>
      <div class="search-results" id="searchResults" role="listbox" aria-label="搜索结果"></div>
    </div>
  </main>

  <section class="docs-page page" id="docsPage" role="region" aria-label="文档页面">
    <div class="docs-nav">
      <button class="docs-nav-btn active" data-doc="charter">成员公约</button>
      <button class="docs-nav-btn" data-doc="disclaimer">免责声明</button>
    </div>
    <div class="docs-content">
      <article class="markdown-body" id="docsBody">加载中...</article>
    </div>
  </section>

  <section class="about-page page" id="aboutPage" role="region" aria-label="关于我们">
    <div class="about-content">
      <article class="markdown-body" id="aboutBody">加载中...</article>
    </div>
  </section>

  <div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal">
      <div class="modal-header">
        <h2 class="modal-title" id="modalTitle">信息</h2>
        <button class="modal-close" id="modalClose" aria-label="关闭弹窗"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div class="modal-body"><div class="markdown-body" id="modalBody"></div></div>
    </div>
  </div>

  <div class="modal-overlay" id="rulesModal" role="dialog" aria-modal="true" aria-labelledby="rulesModalTitle">
    <div class="modal">
      <div class="modal-header">
        <h2 class="modal-title" id="rulesModalTitle">提交须知</h2>
        <button class="modal-close" id="rulesClose" aria-label="关闭弹窗"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div class="modal-body"><div class="markdown-body" id="rulesBody">加载中...</div></div>
      <div class="modal-footer">
        <a href="https://docs.qq.com/form/page/DVVZXV09zUUdDUWJs" target="_blank" rel="noopener noreferrer" class="modal-btn modal-btn-primary">我已阅读，前往填写</a>
      </div>
    </div>
  </div>

  <footer class="footer" role="contentinfo">
    <p>© <span id="footerYear"></span> LinktoFur</p>
    <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">粤ICP备2026000263号</a></p>
  </footer>

  <script is:inline>
    window.BASE_URL = 'https://moke.furry.luxe/';
  </script>
  <script is:inline src="https://cdn.jsdmirror.com/npm/marked/marked.min.js"></script>
  <script is:inline src="/src/scripts/main.js"></script>
</body>
</html>
