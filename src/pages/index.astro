---
const BASE_URL = 'https://api.furry.luxe/moke/';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Moke</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css@5.5.0/github-markdown.min.css">
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" is:inline></script>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    
    :root {
      --c-bg: #0a0a0b;
      --c-bg-soft: #141416;
      --c-bg-mute: #1e1e21;
      --c-border: #2e2e32;
      --c-text: #ffffffde;
      --c-text-2: #ffffffaa;
      --c-text-3: #ffffff66;
      --c-brand: #646cff;
      --c-brand-light: #747bff;
      --c-highlight-bg: rgba(100, 108, 255, 0.14);
      --c-highlight-text: #a8b1ff;
      --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    [data-theme="light"] {
      --c-bg: #ffffff;
      --c-bg-soft: #f9f9f9;
      --c-bg-mute: #f1f1f1;
      --c-border: #e2e2e3;
      --c-text: #213547;
      --c-text-2: #476582;
      --c-text-3: #8e8e93;
      --c-highlight-bg: rgba(100, 108, 255, 0.08);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    html, body { 
      height: 100%;
      font-family: var(--font);
      background: var(--c-bg);
      color: var(--c-text);
      -webkit-font-smoothing: antialiased;
    }

    /* Header */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      height: 64px;
      background: var(--c-bg);
      border-bottom: 1px solid var(--c-border);
    }

    .header-inner {
      max-width: 1200px;
      height: 100%;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 18px;
      font-weight: 600;
      color: var(--c-text);
      text-decoration: none;
    }

    .logo-icon {
      width: 28px;
      height: 28px;
      background: var(--c-brand);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 700;
      font-size: 14px;
    }

    .theme-toggle {
      width: 40px;
      height: 40px;
      border: none;
      background: transparent;
      color: var(--c-text-2);
      cursor: pointer;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s, background 0.2s;
    }

    .theme-toggle:hover {
      color: var(--c-text);
      background: var(--c-bg-mute);
    }

    .theme-toggle svg { width: 20px; height: 20px; }
  </style>
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/" class="logo" id="logoBtn">
        <span class="logo-icon">M</span>
        <span>Moke</span>
      </a>
      <button class="theme-toggle" id="themeToggle" title="切换主题">
        <svg id="moonIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="sunIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>
    </div>
  </header>


  <style is:global>
    /* Home */
    .home {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .home h1 {
      font-size: clamp(40px, 8vw, 72px);
      font-weight: 700;
      letter-spacing: -0.02em;
      background: linear-gradient(120deg, var(--c-brand) 30%, #42d392);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 16px;
    }

    .home p {
      font-size: 18px;
      color: var(--c-text-2);
      margin-bottom: 48px;
    }

    /* Search */
    .search-wrap {
      width: 100%;
      max-width: 560px;
      position: relative;
    }

    .search-box {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 0 20px;
      height: 56px;
      background: var(--c-bg-soft);
      border: 1px solid var(--c-border);
      border-radius: 12px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .search-box:focus-within {
      border-color: var(--c-brand);
      box-shadow: 0 0 0 4px var(--c-highlight-bg);
    }

    .search-box svg {
      width: 20px;
      height: 20px;
      color: var(--c-text-3);
      flex-shrink: 0;
    }

    .search-box input {
      flex: 1;
      height: 100%;
      border: none;
      background: transparent;
      font-size: 16px;
      color: var(--c-text);
      outline: none;
    }

    .search-box input::placeholder { color: var(--c-text-3); }

    .search-box kbd {
      padding: 4px 8px;
      font-size: 12px;
      font-family: var(--font);
      color: var(--c-text-3);
      background: var(--c-bg-mute);
      border: 1px solid var(--c-border);
      border-radius: 4px;
    }

    .search-tip {
      margin-top: 16px;
      font-size: 14px;
      color: var(--c-text-3);
    }

    /* Results */
    .search-results {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      background: var(--c-bg-soft);
      border: 1px solid var(--c-border);
      border-radius: 12px;
      max-height: 420px;
      overflow-y: auto;
      display: none;
      box-shadow: 0 12px 32px rgba(0,0,0,0.3);
    }

    .search-results.show { display: block; }

    .result-item {
      display: block;
      padding: 14px 18px;
      border-bottom: 1px solid var(--c-border);
      cursor: pointer;
      transition: background 0.15s;
    }

    .result-item:last-child { border-bottom: none; }
    .result-item:hover { background: var(--c-bg-mute); }

    .result-title {
      font-size: 15px;
      font-weight: 600;
      color: var(--c-text);
      margin-bottom: 6px;
    }

    .result-path {
      font-size: 12px;
      color: var(--c-brand-light);
      margin-bottom: 8px;
    }

    .result-preview {
      font-size: 14px;
      color: var(--c-text-2);
      line-height: 1.5;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .result-preview mark {
      background: var(--c-highlight-bg);
      color: var(--c-highlight-text);
      padding: 1px 4px;
      border-radius: 3px;
    }

    .no-result {
      padding: 32px;
      text-align: center;
      color: var(--c-text-3);
    }

    /* Article */
    .article-page {
      display: none;
      min-height: 100vh;
      padding: 96px 24px 48px;
    }

    .article-page.show { display: block; }

    .article-inner {
      max-width: 720px;
      margin: 0 auto;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      font-size: 14px;
      color: var(--c-text-2);
      background: var(--c-bg-soft);
      border: 1px solid var(--c-border);
      border-radius: 8px;
      cursor: pointer;
      margin-bottom: 32px;
      transition: all 0.2s;
    }

    .back-btn:hover {
      color: var(--c-text);
      background: var(--c-bg-mute);
    }

    .back-btn svg { width: 16px; height: 16px; }

    .article-meta {
      font-size: 14px;
      color: var(--c-text-3);
      margin-bottom: 12px;
    }

    .article-title {
      font-size: 36px;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 32px;
    }

    .markdown-body {
      background: transparent !important;
      color: var(--c-text) !important;
      font-size: 16px;
      line-height: 1.75;
    }

    [data-theme="dark"] .markdown-body { color-scheme: dark; }

    @media (max-width: 640px) {
      .search-box kbd { display: none; }
      .article-title { font-size: 28px; }
    }
  </style>


  <!-- Home View -->
  <main class="home" id="homeView">
    <h1>Moke</h1>
    <p>搜索你想要的一切</p>
    <div class="search-wrap">
      <div class="search-box">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="searchInput" placeholder="搜索文档..." autocomplete="off">
        <kbd>⌘K</kbd>
      </div>
      <div class="search-results" id="searchResults"></div>
    </div>
    <span class="search-tip">输入 2 个字符开始搜索</span>
  </main>

  <!-- Article View -->
  <div class="article-page" id="articlePage">
    <div class="article-inner">
      <button class="back-btn" id="backBtn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        返回
      </button>
      <div class="article-meta" id="articleMeta"></div>
      <h1 class="article-title" id="articleTitle"></h1>
      <article class="markdown-body" id="articleBody"></article>
    </div>
  </div>

  <script is:inline define:vars={{ BASE_URL }}>
    const API = BASE_URL;
    let articles = [];
    const $ = id => document.getElementById(id);
    const homeView = $('homeView');
    const articlePage = $('articlePage');
    const searchInput = $('searchInput');
    const searchResults = $('searchResults');
    let timer;

    // Theme
    const theme = localStorage.getItem('theme') || 'dark';
    document.documentElement.dataset.theme = theme;
    updateThemeIcon(theme);

    $('themeToggle').onclick = () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      updateThemeIcon(next);
    };

    function updateThemeIcon(t) {
      $('moonIcon').style.display = t === 'dark' ? 'block' : 'none';
      $('sunIcon').style.display = t === 'light' ? 'block' : 'none';
    }

    // Navigation
    $('logoBtn').onclick = e => { e.preventDefault(); goHome(); };
    $('backBtn').onclick = goHome;

    function goHome() {
      homeView.style.display = 'flex';
      articlePage.classList.remove('show');
      searchInput.focus();
    }

    function showArticle(a) {
      homeView.style.display = 'none';
      articlePage.classList.add('show');
      $('articleMeta').textContent = a.path;
      $('articleTitle').textContent = a.name.replace('.md', '');
      $('articleBody').innerHTML = marked.parse(a.content);
      searchResults.classList.remove('show');
      window.scrollTo(0, 0);
    }

    // Load articles
    fetch(API + 'api.php').then(r => r.json()).then(data => {
      if (!data.folders) return;
      const loaded = {};
      data.folders.forEach(folder => {
        fetch(API + 'api.php?category=' + encodeURIComponent(folder))
          .then(r => r.json())
          .then(d => {
            if (!d.articles) return;
            d.articles.forEach(a => {
              const key = a.path + '/' + a.name;
              if (!loaded[key]) {
                loaded[key] = true;
                articles.push({ path: a.path, name: a.name, content: a.content });
              }
            });
          });
      });
    });

    // Search
    searchInput.oninput = e => {
      clearTimeout(timer);
      const q = e.target.value.trim();
      if (q.length < 2) { searchResults.classList.remove('show'); return; }
      timer = setTimeout(() => search(q), 150);
    };

    searchInput.onfocus = () => {
      if (searchInput.value.trim().length >= 2) searchResults.classList.add('show');
    };

    document.onclick = e => {
      if (!e.target.closest('.search-wrap')) searchResults.classList.remove('show');
    };

    document.onkeydown = e => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); goHome(); }
      if (e.key === 'Escape') searchResults.classList.remove('show');
    };

    function esc(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

    function search(q) {
      const lq = q.toLowerCase();
      const res = articles.filter(a => 
        a.name.toLowerCase().includes(lq) || a.content.toLowerCase().includes(lq)
      );

      if (!res.length) {
        searchResults.innerHTML = '<div class="no-result">没有找到结果</div>';
      } else {
        searchResults.innerHTML = res.slice(0, 8).map((a, i) => {
          let preview = '';
          const idx = a.content.toLowerCase().indexOf(lq);
          if (idx !== -1) {
            const s = Math.max(0, idx - 30);
            const e = Math.min(a.content.length, idx + q.length + 50);
            preview = (s > 0 ? '...' : '') + 
              a.content.slice(s, e).replace(/\n/g, ' ').replace(
                new RegExp('(' + esc(q) + ')', 'gi'), '<mark>$1</mark>'
              ) + (e < a.content.length ? '...' : '');
          }
          return `<div class="result-item" data-i="${i}">
            <div class="result-title">${a.name.replace('.md', '')}</div>
            <div class="result-path">${a.path}</div>
            ${preview ? `<div class="result-preview">${preview}</div>` : ''}
          </div>`;
        }).join('');

        searchResults.querySelectorAll('.result-item').forEach((el, i) => {
          el.onclick = () => res[i] && showArticle(res[i]);
        });
      }
      searchResults.classList.add('show');
    }

    searchInput.focus();
  </script>
</body>
</html>
